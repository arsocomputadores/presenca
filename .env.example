PORT=3000
SESSION_SECRET=gere-uma-chave-longa-e-segura

# Deixe USE_MYSQL=false para visualizar o sistema com dados de demonstração
USE_MYSQL=false

# Para MySQL hospedado, prefira usar DB_URL.
# Exemplo:
# DB_URL=mysql://usuario:senha@host:3306/presenca_escolar
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false
DB_URL=

# Datas em que a frequência deve ficar liberada mesmo no fim de semana (separadas por vírgula)
FREQUENCIA_LIBERADA_DATAS=2026-07-04
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_LIMIT=10

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=presenca_escolar
