<%- include('../partials/shell-start') %>

<div class="card" style="max-width:640px">
  <div class="card-header">
    <h3><%= turma ? 'Editar' : 'Nova' %> turma</h3>
    <a href="/turmas" class="btn btn-sm btn-outline">Voltar</a>
  </div>
  <div class="card-body">
    <% if (erro) { %><div class="alert alert-error"><%= erro %></div><% } %>

    <form method="post" action="<%= turma ? '/turmas/' + turma.id : '/turmas' %>">
      <div class="form-grid">
        <div class="form-group">
          <label for="nome">Nome da turma *</label>
          <input type="text" id="nome" name="nome" required placeholder="Ex: 6º A" value="<%= turma ? turma.nome : '' %>">
        </div>
        <div class="form-group">
          <label for="serie">Série *</label>
          <input type="text" id="serie" name="serie" required placeholder="Ex: 6º ano" value="<%= turma ? turma.serie : '' %>">
        </div>
        <div class="form-group">
          <label for="turno">Turno *</label>
          <select id="turno" name="turno" required>
            <option value="matutino" <%= turma && turma.turno === 'matutino' ? 'selected' : '' %>>Matutino</option>
            <option value="vespertino" <%= turma && turma.turno === 'vespertino' ? 'selected' : '' %>>Vespertino</option>
            <option value="noturno" <%= turma && turma.turno === 'noturno' ? 'selected' : '' %>>Noturno</option>
            <option value="integral" <%= turma && turma.turno === 'integral' ? 'selected' : '' %>>Integral</option>
          </select>
        </div>
        <div class="form-group">
          <label for="ano_letivo">Ano Letivo *</label>
          <input type="number" id="ano_letivo" name="ano_letivo" required value="<%= turma ? turma.ano_letivo : new Date().getFullYear() %>">
        </div>
      </div>

      <div class="alert alert-info" style="margin-top:1rem">
        Defina o professor de cada <strong>dia da semana</strong> para o <strong>1º</strong> e o <strong>6º horário</strong>. Se algum campo ficar em branco, o sistema usa o vínculo geral da turma como fallback.
      </div>

      <div class="table-wrap" style="margin-top:1rem">
        <table class="table">
          <thead>
            <tr>
              <th>Dia da Semana</th>
              <th>Professor do 1º horário</th>
              <th>Professor do 6º horário</th>
            </tr>
          </thead>
          <tbody>
            <% diasSemana.forEach(function(dia) { %>
              <tr>
                <td><strong><%= dia.label %></strong></td>
                <% [1, 6].forEach(function(horario) { %>
                  <td>
                    <select name="professor_<%= dia.value %>_<%= horario %>">
                      <option value="">Selecionar depois</option>
                      <% professores.forEach(function(professor) { %>
                        <% const valorAtual = turma?.escala_semana?.[dia.value]?.[horario]?.professor_id || turma?.['professor_' + dia.value + '_' + horario] || ''; %>
                        <% const selecionado = String(valorAtual) === String(professor.id); %>
                        <option value="<%= professor.id %>" <%= selecionado ? 'selected' : '' %>>
                          <%= professor.nome %>
                        </option>
                      <% }) %>
                    </select>
                  </td>
                <% }) %>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <div style="margin-top:1rem">
        <div class="form-group">
          <label for="professor_conselheiro_id">Professor Conselheiro</label>
          <select id="professor_conselheiro_id" name="professor_conselheiro_id">
            <option value="">Nenhum</option>
            <% professores.forEach(function(professor) { %>
              <option value="<%= professor.id %>" <%= turma && String(turma.professor_conselheiro_id) === String(professor.id) ? 'selected' : '' %>><%= professor.nome %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group" style="margin-top:.5rem">
          <label>
            <input type="checkbox" name="conselheiro_pode_lancar" value="1" <%= turma && Number(turma.conselheiro_pode_lancar) === 1 ? 'checked' : '' %> > Permitir que o conselheiro lance frequência
          </label>
        </div>
      </div>

      <div style="margin-top:1.25rem;display:flex;gap:0.75rem">
        <button type="submit" class="btn btn-primary">Salvar turma</button>
        <a href="/turmas" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/shell-end') %>
