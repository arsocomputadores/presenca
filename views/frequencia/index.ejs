<%- include('../partials/shell-start') %>

<% if (sucesso) { %><div class="alert alert-success"><%= sucesso %></div><% } %>
<% if (erro) { %><div class="alert alert-error"><%= erro %></div><% } %>

<div class="card freq-page-card">
  <div class="card-header freq-card-header">
    <h3>Frequência diária — <%= formatarData(data) %></h3>
  </div>
  <div class="card-body freq-card-body">
    <div class="freq-sticky-header">
      <form method="get" action="/frequencia" class="freq-toolbar">
        <div class="form-group">
          <label for="turma_id">Turma</label>
          <select name="turma_id" id="turma_id" onchange="this.form.submit()">
            <% turmas.forEach(function(t) { %>
              <option value="<%= t.id %>" <%= turmaId == t.id ? 'selected' : '' %>><%= t.nome %> — <%= t.serie %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label for="data">Data</label>
          <input type="date" name="data" id="data" value="<%= data %>" onchange="this.form.submit()">
        </div>
        <div class="form-group">
          <label for="horario">Horário</label>
          <select name="horario" id="horario" onchange="this.form.submit()">
            <option value="1" <%= horario == 1 ? 'selected' : '' %>>1º Horário</option>
            <option value="6" <%= horario == 6 ? 'selected' : '' %>>6º Horário</option>
          </select>
        </div>
      </form>

      <div class="freq-legend">
        <span><i class="dot dot-P"></i> P — Presente</span>
        <span><i class="dot dot-F"></i> F — Falta</span>
        <span><i class="dot dot-J"></i> J — Justificada</span>
      </div>
    </div>

    <% if (jaLancada) { %>
      <div class="alert alert-info">
        A frequência desta turma já foi lançada para o <strong><%= horario %>º horário</strong> em <strong><%= formatarData(data) %></strong>.
        Escolha outro horário ou outra data para continuar.
      </div>
    <% } else if (alunos.length === 0) { %>
      <p style="color:var(--muted)">Nenhum aluno ativo nesta turma.</p>
    <% } else { %>
      <form method="post" action="/frequencia" id="form-frequencia">
      <input type="hidden" name="turma_id" value="<%= turmaId %>">
      <input type="hidden" name="data" value="<%= data %>">
      <input type="hidden" name="horario" value="<%= horario %>">
      
      <div class="table-wrap freq-table-wrap">
          <table class="freq-table">
            <thead>
              <tr>
                <th>Código</th>
                <th>Aluno</th>
                <th>Presença</th>
                <th>Observação</th>
              </tr>
            </thead>
            <tbody>
              <% alunos.forEach(function(a) { %>
                <tr class="student-freq-card">
                  <td data-label="Código">
                    <span class="student-code"><%= a.codigo_formatado %></span>
                  </td>
                  <td class="student-info" data-label="Aluno">
                    <span class="student-name"><%= a.nome %></span>
                  </td>
                  <td class="freq-controls" data-label="Presença">
                    <input type="hidden" name="aluno_id" value="<%= a.id %>">
                    <div class="freq-buttons-grid freq-status-group" data-aluno="<%= a.id %>">
                      <% ['P','F','J'].forEach(function(s) { %>
                        <button type="button"
                          class="freq-btn <%= a.status === s ? 'active-' + s : '' %>"
                          data-aluno-id="<%= a.id %>"
                          data-status="<%= s %>"
                          onclick="setStatusFromButton(this)"><%= s %></button>
                      <% }) %>
                      <input type="hidden" name="status_<%= a.id %>" id="status_<%= a.id %>" value="<%= a.status || '' %>">
                    </div>
                  </td>
                  <td class="obs-container" data-label="Observação">
                    <input type="text" name="obs_<%= a.id %>" placeholder="Observação (opcional)" value="<%= a.observacao || '' %>" class="form-control-sm obs-input-mobile">
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div class="form-actions-bar mobile-action-bar freq-actions-bar">
          <a href="/turmas" class="btn btn-secondary">Voltar para turmas</a>
          <button type="button" class="btn btn-secondary" onclick="marcarTodos('P')">Todos P</button>
          <button type="submit" class="btn btn-primary">Salvar Frequência</button>
        </div>
      </form>
    <% } %>
  </div>
</div>

<%- include('../partials/shell-end') %>
