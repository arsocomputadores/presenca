<%- include('../partials/shell-start') %>

<% if (sucesso) { %><div class="alert alert-success alert-save-success" id="alert-freq-sucesso" role="status"><%= sucesso %></div><% } %>
<% if (erro) { %><div class="alert alert-error" id="alert-freq-erro"><%= erro %></div><% } %>

<div class="card freq-page-card">
  <div class="card-header freq-card-header">
    <h3>Frequência diária — <%= formatarData(data) %></h3>
  </div>
  <div class="card-body freq-card-body">
    <div class="freq-sticky-header">
      <form method="get" action="/frequencia" class="freq-toolbar">
        <div class="form-group">
          <label for="turma_id">Turma</label>
          <% if (usuario.perfil === 'professor') { %>
            <select name="turma_id" id="turma_id" onchange="this.form.submit()">
              <% if (turmasLancamento && turmasLancamento.length) { %>
                <% turmasLancamento.forEach(function(t) { %>
                  <option value="<%= t.id %>" <%= turmaId == t.id ? 'selected' : '' %>><%= t.nome %> — <%= t.serie %></option>
                <% }) %>
              <% } else { %>
                <% turmasConsulta.forEach(function(t) { %>
                  <option value="<%= t.id %>" <%= turmaId == t.id ? 'selected' : '' %>><%= t.nome %> — <%= t.serie %></option>
                <% }) %>
              <% } %>
            </select>
            <button type="button" class="btn btn-link" onclick="document.getElementById('outras-turmas').classList.toggle('hidden')">Ver outras turmas</button>
            <div id="outras-turmas" class="hidden" style="margin-top:.5rem">
              <label>Outras turmas (consulta)</label>
              <select onchange="document.getElementById('select-outras').value=this.value; this.form.submit()" id="select-outras">
                <option value="">-- selecione --</option>
                <% (turmasConsulta || []).forEach(function(t) { %>
                  <% const isLanc = (turmasLancamento || []).some(tt => tt.id === t.id); %>
                  <% if (!isLanc) { %>
                    <option value="<%= t.id %>"><%= t.nome %> — <%= t.serie %></option>
                  <% } %>
                <% }) %>
              </select>
            </div>
          <% } else { %>
            <select name="turma_id" id="turma_id" onchange="this.form.submit()">
              <% turmasConsulta.forEach(function(t) { %>
                <option value="<%= t.id %>" <%= turmaId == t.id ? 'selected' : '' %>><%= t.nome %> — <%= t.serie %></option>
              <% }) %>
            </select>
          <% } %>
        </div>
        <div class="form-group">
          <label for="data">Data</label>
          <input type="date" name="data" id="data" value="<%= data %>" onchange="this.form.submit()">
        </div>
        <% if (!(usuario.perfil === 'professor' && horariosDisponiveis.length === 1)) { %>
          <div class="form-group">
            <label for="horario">Horário</label>
            <% if (usuario.perfil === 'professor' && horariosDisponiveis.length === 0) { %>
              <input type="hidden" name="horario" value="<%= horario %>">
              <input type="text" value="Sem horário liberado" readonly>
            <% } else { %>
              <select name="horario" id="horario" onchange="this.form.submit()">
                <% (usuario.perfil === 'professor' ? horariosDisponiveis : [1, 6]).forEach(function(h) { %>
                  <option value="<%= h %>" <%= horario == h ? 'selected' : '' %>><%= h %>º Horário</option>
                <% }) %>
              </select>
            <% } %>
          </div>
        <% } else { %>
          <input type="hidden" name="horario" value="<%= horario %>">
        <% } %>
      </form>

      <div class="freq-legend">
        <span><i class="dot dot-P"></i> P — Presente</span>
        <span><i class="dot dot-F"></i> F — Falta</span>
        <span><i class="dot dot-J"></i> J — Justificada</span>
      </div>

      <% if (diaSemanaAtual) { %>
        <div class="alert alert-info" style="margin-top:0.75rem">
          Dia selecionado: <strong><%= diaSemanaAtual.label %></strong>.
        </div>
      <% } %>

      <% if (turmaSelecionada) { %>
        <div class="alert alert-info" style="margin-top:0.75rem">
          Professor do <strong>1º horário</strong>:
          <strong><%= diaSemanaAtual ? (turmaSelecionada.escala_semana?.[diaSemanaAtual.value]?.[1]?.professor_nome || turmaSelecionada.professor_primeiro_horario_nome || 'sem marcação específica') : (turmaSelecionada.professor_primeiro_horario_nome || 'sem marcação específica') %></strong>.
          Professor do <strong>6º horário</strong>:
          <strong><%= diaSemanaAtual ? (turmaSelecionada.escala_semana?.[diaSemanaAtual.value]?.[6]?.professor_nome || turmaSelecionada.professor_sexto_horario_nome || 'sem marcação específica') : (turmaSelecionada.professor_sexto_horario_nome || 'sem marcação específica') %></strong>.
        </div>
      <% } %>

      <% if (usuario.perfil === 'professor' && turmaSelecionada) { %>
        <div class="alert alert-warning" style="margin-top:0.75rem">
          <% if (String(turmaSelecionada.turno).toLowerCase() === 'manha' || String(turmaSelecionada.turno).toLowerCase() === 'matutino') { %>
            Limites do matutino: <strong>1º horário até 9h30</strong> e <strong>6º horário até 12h30</strong>.
          <% } else if (String(turmaSelecionada.turno).toLowerCase() === 'tarde' || String(turmaSelecionada.turno).toLowerCase() === 'vespertino') { %>
            Limites do vespertino: <strong>1º horário até 14h30</strong> e <strong>6º horário até 18h10</strong>.
          <% } %>
        </div>
      <% } %>
    </div>

    <% if (usuario.perfil === 'professor' && !podeSalvarFrequencia && turmaSelecionada) { %>
      <div class="alert alert-info">
        Você está consultando a frequência da turma <strong><%= turmaSelecionada.nome %></strong>. O lançamento permanece restrito às turmas vinculadas ao seu cadastro.
      </div>
    <% } %>

    <% if (horarioForaDoPrazo && !jaLancada && usuario.perfil === 'professor' && !podeLancarForaHorario) { %>
      <div class="alert alert-warning">
        O prazo para lançamento desta frequência já terminou. Solicite ao administrador a liberação para lançar fora do horário.
      </div>

      <% if (solicitacaoLancamentoAtual && solicitacaoLancamentoAtual.status === 'pendente') { %>
        <div class="alert alert-info" style="margin-top:1rem">
          Sua solicitação de lançamento fora do horário já foi enviada ao administrador e está pendente.
        </div>
      <% } else if (solicitacaoLancamentoAtual && solicitacaoLancamentoAtual.status === 'liberada') { %>
        <div class="alert alert-success" style="margin-top:1rem">
          Sua solicitação foi liberada. Atualize a página se o formulário não aparecer automaticamente.
        </div>
      <% } else { %>
        <div class="card" style="margin-top:1rem">
          <div class="card-header">
            <h4>Solicitar Lançamento Fora do Horário</h4>
          </div>
          <div class="card-body">
            <form method="post" action="/frequencia/solicitar-lancamento-fora-horario">
              <input type="hidden" name="turma_id" value="<%= turmaId %>">
              <input type="hidden" name="data" value="<%= data %>">
              <input type="hidden" name="horario" value="<%= horario %>">
              <div class="form-group" style="margin-bottom:0.75rem">
                <label for="motivo_solicitacao_lancamento">Motivo da solicitação</label>
                <textarea name="motivo_solicitacao_lancamento" id="motivo_solicitacao_lancamento" rows="3" placeholder="Explique por que o lançamento será feito após o horário limite." required></textarea>
              </div>
              <button type="submit" class="btn btn-primary">Solicitar ao administrador</button>
            </form>
          </div>
        </div>
      <% } %>
    <% } else if (jaLancada && !modoEdicao) { %>
      <div class="alert alert-info">
        A frequência desta turma já foi lançada para o <strong><%= horario %>º horário</strong> em <strong><%= formatarData(data) %></strong>.
        <% if (usuario.perfil === 'admin') { %>
          Você pode liberar a alteração para o solicitante ou editar diretamente.
        <% } else { %>
          Solicite ao administrador a liberação para alterar.
        <% } %>
      </div>

      <% if (usuario.perfil === 'professor' && alunos.length > 0) { %>
        <div class="alert alert-success" style="margin-top:1rem">
          Frequência lançada com sucesso para <strong><%= turmaSelecionada?.nome || 'a turma' %></strong> no <strong><%= horario %>º horário</strong>.
        </div>
        <div class="table-wrap freq-table-wrap">
          <table class="freq-table">
            <thead>
              <tr>
                <th>Código</th>
                <th>Aluno</th>
                <th>Presença</th>
                <th>Observação</th>
              </tr>
            </thead>
            <tbody>
              <% alunos.forEach(function(a) { %>
                <tr class="student-freq-card">
                  <td data-label="Código">
                    <span class="student-code"><%= a.codigo_formatado %></span>
                  </td>
                  <td class="student-info" data-label="Aluno">
                    <span class="student-name"><%= a.nome %></span>
                  </td>
                  <td data-label="Presença">
                    <% if (a.status === 'P') { %>
                      <span class="badge badge-success">Presente</span>
                    <% } else if (a.status === 'F') { %>
                      <span class="badge badge-error">Falta</span>
                    <% } else if (a.status === 'J') { %>
                      <span class="badge badge-warning">Justificada</span>
                    <% } else { %>
                      <span class="badge">Sem status</span>
                    <% } %>
                  </td>
                  <td data-label="Observação">
                    <%= a.observacao || '—' %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else if (usuario.perfil === 'admin') { %>
        <div class="card" style="margin-top:1rem">
          <div class="card-header">
            <h4>Alteração da Frequência Lançada</h4>
          </div>
          <div class="card-body">
            <div class="inline-actions">
              <a href="/frequencia?turma_id=<%= turmaId %>&data=<%= data %>&horario=<%= horario %>&editar=1" class="btn btn-primary">Editar frequência lançada</a>
            </div>

            <% if (solicitacoesPendentesAdmin && solicitacoesPendentesAdmin.length > 0) { %>
              <div style="margin-top:1rem">
                <% solicitacoesPendentesAdmin.forEach(function(item) { %>
                  <div class="card" style="margin-bottom:1rem">
                    <div class="card-body">
                      <div style="font-weight:700; margin-bottom:.35rem">
                        <%= item.solicitante_nome %> -
                        <span class="badge <%= item.status === 'liberada' ? 'badge-success' : 'badge-warning' %>">
                          <%= item.status === 'liberada' ? 'Liberada' : 'Pendente' %>
                        </span>
                      </div>
                      <div style="margin-bottom:.5rem"><strong>Motivo:</strong> <%= item.motivo %></div>
                      <% if (item.status === 'pendente') { %>
                        <form method="post" action="/frequencia/liberar-edicao" class="inline-actions" style="margin:0">
                          <input type="hidden" name="solicitacao_id" value="<%= item.id %>">
                          <input type="hidden" name="turma_id" value="<%= turmaId %>">
                          <input type="hidden" name="data" value="<%= data %>">
                          <input type="hidden" name="horario" value="<%= horario %>">
                          <button type="submit" class="btn btn-secondary">Liberar alteração</button>
                        </form>
                      <% } else { %>
                        <div class="text-muted">Liberação feita por <%= item.liberado_por_nome || 'administrador' %>.</div>
                      <% } %>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <p class="text-muted" style="margin-top:1rem; margin-bottom:0">Nenhuma solicitação pendente para esta frequência.</p>
            <% } %>
          </div>
        </div>
      <% } else if (solicitacaoEdicaoAtual && solicitacaoEdicaoAtual.status === 'pendente') { %>
        <div class="alert alert-warning" style="margin-top:1rem">
          Sua solicitação de alteração já foi enviada ao administrador e ainda está pendente.
        </div>
      <% } else if (solicitacaoEdicaoAtual && solicitacaoEdicaoAtual.status === 'liberada') { %>
        <div class="alert alert-success" style="margin-top:1rem">
          Sua solicitação foi liberada. A edição da frequência já está disponível abaixo.
        </div>
      <% } else { %>
        <div class="card" style="margin-top:1rem">
          <div class="card-header">
            <h4>Solicitar Liberação ao Administrador</h4>
          </div>
          <div class="card-body">
            <form method="post" action="/frequencia/solicitar-edicao">
              <input type="hidden" name="turma_id" value="<%= turmaId %>">
              <input type="hidden" name="data" value="<%= data %>">
              <input type="hidden" name="horario" value="<%= horario %>">
              <div class="form-group" style="margin-bottom:0.75rem">
                <label for="motivo_solicitacao">Motivo da solicitação</label>
                <textarea name="motivo_solicitacao" id="motivo_solicitacao" rows="3" placeholder="Explique ao administrador por que a frequência precisa ser alterada." required></textarea>
              </div>
              <button type="submit" class="btn btn-primary">Solicitar ao administrador</button>
            </form>
          </div>
        </div>
      <% } %>
    <% } else if (horarioForaDoPrazo && !jaLancada && usuario.perfil === 'admin' && solicitacoesLancamentoPendentesAdmin && solicitacoesLancamentoPendentesAdmin.length > 0) { %>
      <div class="alert alert-info">
        Há solicitação(ões) pendente(s) para lançamento fora do horário nesta frequência.
      </div>
      <div class="card" style="margin-top:1rem">
        <div class="card-header">
          <h4>Liberações de Lançamento Fora do Horário</h4>
        </div>
        <div class="card-body">
          <% solicitacoesLancamentoPendentesAdmin.forEach(function(item) { %>
            <div class="card" style="margin-bottom:1rem">
              <div class="card-body">
                <div style="font-weight:700; margin-bottom:.35rem">
                  <%= item.solicitante_nome %> -
                  <span class="badge <%= item.status === 'liberada' ? 'badge-success' : 'badge-warning' %>">
                    <%= item.status === 'liberada' ? 'Liberada' : 'Pendente' %>
                  </span>
                </div>
                <div style="margin-bottom:.5rem"><strong>Motivo:</strong> <%= item.motivo %></div>
                <% if (item.status === 'pendente') { %>
                  <form method="post" action="/frequencia/liberar-lancamento-fora-horario" class="inline-actions" style="margin:0">
                    <input type="hidden" name="solicitacao_id" value="<%= item.id %>">
                    <input type="hidden" name="turma_id" value="<%= turmaId %>">
                    <input type="hidden" name="data" value="<%= data %>">
                    <input type="hidden" name="horario" value="<%= horario %>">
                    <button type="submit" class="btn btn-secondary">Liberar lançamento fora do horário</button>
                  </form>
                <% } else { %>
                  <div class="text-muted">Liberação feita por <%= item.liberado_por_nome || 'administrador' %>.</div>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } else if (!turmaSelecionada) { %>
      <p style="color:var(--muted)">Selecione uma turma para consultar a frequência.</p>
    <% } else if (alunos.length === 0) { %>
      <p style="color:var(--muted)">Nenhum aluno ativo nesta turma.</p>
    <% } else if (!podeSalvarFrequencia) { %>
      <div class="alert alert-info" style="margin-bottom:1rem">
        Consulta liberada para esta turma. Para lançar ou alterar a frequência, é necessário ter vínculo com a turma.
      </div>
      <div class="table-wrap freq-table-wrap">
        <table class="freq-table">
          <thead>
            <tr>
              <th>Código</th>
              <th>Aluno</th>
              <th>Presença</th>
              <th>Observação</th>
            </tr>
          </thead>
          <tbody>
            <% alunos.forEach(function(a) { %>
              <tr class="student-freq-card">
                <td data-label="Código">
                  <span class="student-code"><%= a.codigo_formatado %></span>
                </td>
                <td class="student-info" data-label="Aluno">
                  <span class="student-name"><%= a.nome %></span>
                </td>
                <td data-label="Presença">
                  <% if (a.status === 'P') { %>
                    <span class="badge badge-success">Presente</span>
                  <% } else if (a.status === 'F') { %>
                    <span class="badge badge-error">Falta</span>
                  <% } else if (a.status === 'J') { %>
                    <span class="badge badge-warning">Justificada</span>
                  <% } else { %>
                    <span class="badge">Sem status</span>
                  <% } %>
                </td>
                <td data-label="Observação">
                  <%= a.observacao || '—' %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <form method="post" action="/frequencia" id="form-frequencia">
      <input type="hidden" name="turma_id" value="<%= turmaId %>">
      <input type="hidden" name="data" value="<%= data %>">
      <input type="hidden" name="horario" value="<%= horario %>">
      <% if (solicitacaoEdicaoAtual && solicitacaoEdicaoAtual.id) { %>
        <input type="hidden" name="solicitacao_edicao_id" value="<%= solicitacaoEdicaoAtual.id %>">
      <% } %>
      <% if (solicitacaoLancamentoAtual && solicitacaoLancamentoAtual.id) { %>
        <input type="hidden" name="solicitacao_lancamento_id" value="<%= solicitacaoLancamentoAtual.id %>">
      <% } %>
      
      <% if (modoEdicao) { %>
        <div class="alert alert-warning" style="margin-bottom:1rem">
          Você está alterando uma frequência já lançada. Informe a justificativa obrigatória antes de salvar.
        </div>
        <div class="form-group" style="margin-bottom:1rem">
          <label for="justificativa_alteracao">Justificativa da alteração</label>
          <textarea name="justificativa_alteracao" id="justificativa_alteracao" rows="3" placeholder="Descreva o motivo da alteração desta frequência." required></textarea>
        </div>
      <% } else if (horarioForaDoPrazo && podeLancarForaHorario) { %>
        <div class="alert alert-success" style="margin-bottom:1rem">
          O administrador liberou este lançamento fora do horário. Faça o lançamento normalmente abaixo.
        </div>
      <% } %>
      
      <div class="table-wrap freq-table-wrap">
          <table class="freq-table">
            <thead>
              <tr>
                <th>Código</th>
                <th>Aluno</th>
                <th>Presença</th>
                <th>Observação</th>
              </tr>
            </thead>
            <tbody>
              <% alunos.forEach(function(a) { %>
                <tr class="student-freq-card">
                  <td data-label="Código">
                    <span class="student-code"><%= a.codigo_formatado %></span>
                  </td>
                  <td class="student-info" data-label="Aluno">
                    <span class="student-name"><%= a.nome %></span>
                  </td>
                  <td class="freq-controls" data-label="Presença">
                    <input type="hidden" name="aluno_id" value="<%= a.id %>">
                    <div class="freq-buttons-grid freq-status-group" data-aluno="<%= a.id %>">
                      <% ['P','F','J'].forEach(function(s) { %>
                        <button type="button"
                          class="freq-btn <%= a.status === s ? 'active-' + s : '' %>"
                          data-aluno-id="<%= a.id %>"
                          data-status="<%= s %>"
                          onclick="setStatusFromButton(this)"><%= s %></button>
                      <% }) %>
                      <input type="hidden" name="status_<%= a.id %>" id="status_<%= a.id %>" value="<%= a.status || '' %>">
                    </div>
                  </td>
                  <td class="obs-container" data-label="Observação">
                    <input type="text" name="obs_<%= a.id %>" placeholder="Observação (opcional)" value="<%= a.observacao || '' %>" class="form-control-sm obs-input-mobile">
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div class="form-actions-bar mobile-action-bar freq-actions-bar">
          <a href="/turmas" class="btn btn-secondary">Voltar para turmas</a>
          <button type="button" class="btn btn-secondary" onclick="marcarTodos('P')">Todos P</button>
          <button type="submit" class="btn btn-primary"><%= modoEdicao ? 'Salvar Alteração' : 'Salvar Frequência' %></button>
        </div>
      </form>
    <% } %>
  </div>
</div>

<%- include('../partials/shell-end') %>
