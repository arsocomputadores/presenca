<%- include('../partials/shell-start') %>

<div class="card" style="max-width:520px">
  <div class="card-header">
    <h3>Transferir aluno</h3>
    <a href="/alunos" class="btn btn-sm btn-outline">Voltar</a>
  </div>
  <div class="card-body">
    <% if (erro) { %><div class="alert alert-error"><%= erro %></div><% } %>

    <p style="margin-top:0">
      <strong><%= aluno.codigo_formatado %> — <%= aluno.nome %></strong><br>
      Turma atual: <strong><%= aluno.turma_nome %></strong>
    </p>

    <form method="post" action="/alunos/<%= aluno.id %>/transferir" style="margin-top:1.25rem">
      <div class="form-group">
        <label for="turma_id">Nova turma *</label>
        <select id="turma_id" name="turma_id" required>
          <option value="">Selecione a turma destino...</option>
          <% turmas.forEach(function(t) { %>
            <option value="<%= t.id %>"><%= t.nome %> — <%= t.serie %> (<%= t.turno %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label for="data_transferencia">Data da transferência</label>
        <input type="date" id="data_transferencia" name="data_transferencia" value="<%= new Date().toISOString().slice(0,10) %>">
      </div>
      <div class="form-group">
        <label for="motivo">Motivo</label>
        <select id="motivo" name="motivo">
          <option value="transferencia">Transferência interna</option>
          <option value="outro">Outro</option>
        </select>
      </div>
      <div style="margin-top:1.25rem;display:flex;gap:0.75rem">
        <button type="submit" class="btn btn-primary">Confirmar transferência</button>
        <a href="/alunos" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/shell-end') %>
