<%- include('../partials/shell-start') %>

<div class="card" style="max-width:800px">
  <div class="card-header">
    <h3><%= alunosParsed ? 'Confirmar Importação' : 'Importar Alunos (PDF)' %></h3>
    <a href="/alunos" class="btn btn-sm btn-outline">Voltar</a>
  </div>
  <div class="card-body">
    <% if (erro) { %><div class="alert alert-error"><%= erro %></div><% } %>

    <% if (!alunosParsed) { %>
      <form method="post" action="/alunos/importar/preview" enctype="multipart/form-data">
        <div class="alert alert-info">
          O sistema tentará extrair alunos do PDF. O formato esperado é <strong>"Código - Nome"</strong> ou <strong>"Código / Nome"</strong>.
        </div>
        
        <div class="form-group">
          <label for="turma_id">Turma de Destino *</label>
          <select id="turma_id" name="turma_id" required>
            <option value="">Selecione a turma...</option>
            <% turmas.forEach(function(t) { %>
              <option value="<%= t.id %>"><%= t.nome %> — <%= t.serie %></option>
            <% }) %>
          </select>
        </div>

        <div class="form-group" style="margin-top:1rem">
          <label for="pdf">Selecione o arquivo PDF *</label>
          <input type="file" id="pdf" name="pdf" accept=".pdf" required>
        </div>

        <div style="margin-top:1.5rem">
          <button type="submit" class="btn btn-primary">Analisar PDF</button>
        </div>
      </form>
    <% } else { %>
      <form method="post" action="/alunos/importar/confirmar">
        <input type="hidden" name="turma_id" value="<%= turma_id %>">
        
        <div class="alert alert-success">
          Foram encontrados <strong><%= alunosParsed.length %></strong> alunos. Verifique os dados abaixo antes de confirmar.
        </div>

        <div style="max-height: 400px; overflow-y: auto; border: 1px solid #ddd; border-radius: 4px; margin-bottom: 1.5rem;">
          <table class="table" style="margin:0">
            <thead>
              <tr>
                <th>Código</th>
                <th>Nome</th>
                <th>Nascimento</th>
              </tr>
            </thead>
            <tbody>
              <% alunosParsed.forEach(function(aluno) { %>
                <tr>
                  <td>
                    <input type="text" name="codigos" value="<%= aluno.codigo %>" class="form-control-sm" style="width: 100px">
                  </td>
                  <td>
                    <input type="text" name="nomes" value="<%= aluno.nome %>" class="form-control-sm" style="width: 100%">
                  </td>
                  <td>
                    <input type="date" name="datas_nascimento" value="<%= aluno.data_nascimento || '' %>" class="form-control-sm">
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div style="display:flex; gap:0.75rem">
          <button type="submit" class="btn btn-primary">Confirmar e Importar <%= alunosParsed.length %> Alunos</button>
          <a href="/alunos/importar" class="btn btn-secondary">Cancelar e tentar outro arquivo</a>
        </div>
      </form>
    <% } %>
  </div>
</div>

<%- include('../partials/shell-end') %>
