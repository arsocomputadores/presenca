<%- include('../partials/shell-start') %>

<div class="card" style="max-width: 800px; margin-bottom: 1.5rem;">
  <div class="card-header">
    <h3>Cadastrar Feriado / Recesso</h3>
  </div>
  <div class="card-body">
    <% if (erro) { %><div class="alert alert-error"><%= erro %></div><% } %>
    <% if (sucesso) { %><div class="alert alert-success"><%= sucesso %></div><% } %>

    <form method="post" action="/calendario" class="form-grid">
      <div class="form-group">
        <label for="data">Data</label>
        <input type="date" name="data" id="data" required>
      </div>
      <div class="form-group">
        <label for="descricao">Descrição</label>
        <input type="text" name="descricao" id="descricao" placeholder="Ex: Independência do Brasil" required>
      </div>
      <div style="display:flex; align-items:flex-end;">
        <button type="submit" class="btn btn-primary">Adicionar</button>
      </div>
    </form>
  </div>
</div>

<div class="card" style="max-width: 800px;">
  <div class="card-header">
    <h3>Lista de Feriados</h3>
  </div>
  <div class="card-body">
    <% if (feriados.length === 0) { %>
      <p style="color:var(--muted)">Nenhum feriado cadastrado.</p>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Data</th>
              <th>Descrição</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% feriados.forEach(function(f) { %>
              <tr>
                <td><%= formatarData(f.data) %></td>
                <td><%= f.descricao %></td>
                <td>
                  <form action="/calendario/<%= f.id %>/excluir" method="post" style="display:inline" onsubmit="return confirm('Excluir este feriado?')">
                    <button type="submit" class="btn btn-sm btn-outline" style="color:var(--danger)">Excluir</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/shell-end') %>
