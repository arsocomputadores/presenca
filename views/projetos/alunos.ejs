<%- include('../partials/shell-start') %>

<% if (sucesso) { %><div class="alert alert-success"><%= sucesso %></div><% } %>
<% if (erro) { %><div class="alert alert-error"><%= erro %></div><% } %>

<div class="card-header" style="margin-bottom: 1.5rem;">
  <h3>Gerenciar Alunos — <%= projeto.nome %></h3>
  <a href="/projetos" class="btn btn-sm btn-outline">Voltar para Projetos</a>
</div>

<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card-header" style="display:flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;">
    <h4 style="margin: 0;">Frequência do Projeto</h4>
    <form method="get" action="/projetos/<%= projeto.id %>/alunos" style="display:flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
      <input type="month" name="periodo" class="form-control" value="<%= periodo %>" style="max-width: 180px;">
      <button type="submit" class="btn btn-sm btn-primary">Atualizar</button>
    </form>
  </div>
  <div class="card-body">
    <% if (!relatorioProjeto || relatorioProjeto.length === 0) { %>
      <p class="text-muted">Nenhum lançamento encontrado para o período selecionado.</p>
    <% } else { %>
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Código</th>
              <th>Aluno</th>
              <th>Turma</th>
              <th style="width: 90px; text-align: right;">Aulas</th>
              <th style="width: 70px; text-align: right;">P</th>
              <th style="width: 70px; text-align: right;">F</th>
              <th style="width: 70px; text-align: right;">J</th>
              <th style="width: 110px; text-align: right;">% Pres.</th>
              <th style="width: 110px; text-align: right;">% Falt.</th>
            </tr>
          </thead>
          <tbody>
            <% relatorioProjeto.forEach(function(r) { %>
              <tr>
                <td><%= r.codigo_formatado %></td>
                <td><%= r.nome %></td>
                <td><%= r.turma || '-' %></td>
                <td style="text-align: right;"><%= r.dias_lancados %></td>
                <td style="text-align: right;"><%= r.presencas %></td>
                <td style="text-align: right;"><%= r.faltas %></td>
                <td style="text-align: right;"><%= r.justificadas %></td>
                <td style="text-align: right;"><%= Number(r.percentual_presenca || 0).toFixed(2) %>%</td>
                <td style="text-align: right;"><%= Number(r.percentual_faltas || 0).toFixed(2) %>%</td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
  
  <!-- Coluna 1: Alunos Participantes -->
  <div class="card">
    <div class="card-header">
      <h4>Alunos no Projeto (<%= alunosProjeto.length %>)</h4>
    </div>
    <div class="card-body">
      <% if (alunosProjeto.length === 0) { %>
        <p class="text-muted">Nenhum aluno inserido neste projeto ainda.</p>
      <% } else { %>
        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr>
                <th>Código</th>
                <th>Nome</th>
                <th style="width: 80px">Ação</th>
              </tr>
            </thead>
            <tbody>
              <% alunosProjeto.forEach(function(a) { %>
                <tr>
                  <td><%= a.codigo_formatado %></td>
                  <td><%= a.nome %></td>
                  <td>
                    <form action="/projetos/<%= projeto.id %>/alunos/remover" method="post" onsubmit="return confirm('Excluir aluno do projeto?')">
                      <input type="hidden" name="aluno_id" value="<%= a.id %>">
                      <button type="submit" class="btn btn-sm btn-danger">Excluir</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Coluna 2: Adicionar Alunos -->
  <div class="card">
    <div class="card-header">
      <h4>Inserir Alunos</h4>
    </div>
    <div class="card-body">
      <div class="form-group" style="margin-bottom: 1rem;">
        <input type="text" id="filtro-disponiveis" placeholder="Buscar aluno por nome ou código..." class="form-control" oninput="filtrarAlunosDisponiveis(this.value)">
      </div>

      <div class="aluno-check-list" style="max-height: 500px; overflow-y: auto;">
        <% if (alunosDisponiveis.length === 0) { %>
          <p class="text-muted">Todos os alunos ativos já estão no projeto ou não há alunos cadastrados.</p>
        <% } else { %>
          <% alunosDisponiveis.forEach(function(a) { %>
            <div class="aluno-check-item available-student" data-busca="<%= a.codigo_nome.toLowerCase() %>" style="display: flex; justify-content: space-between; align-items: center; padding: 0.5rem; border-bottom: 1px solid var(--border);">
              <div>
                <span class="codigo-cell" style="font-weight: bold;"><%= a.codigo_formatado %></span>
                <span class="nome-cell"><%= a.nome %></span>
                <div style="font-size: 0.75rem; color: var(--muted);"><%= a.turma_nome %></div>
              </div>
              <form action="/projetos/<%= projeto.id %>/alunos/adicionar" method="post">
                <input type="hidden" name="aluno_id" value="<%= a.id %>">
                <button type="submit" class="btn btn-sm btn-primary">Inserir</button>
              </form>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>

</div>

<script>
function filtrarAlunosDisponiveis(termo) {
  const q = termo.toLowerCase();
  document.querySelectorAll('.available-student').forEach((item) => {
    const busca = item.dataset.busca || '';
    item.style.display = busca.includes(q) ? 'flex' : 'none';
  });
}
</script>

<%- include('../partials/shell-end') %>
