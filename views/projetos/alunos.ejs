<%- include('../partials/shell-start') %>

<% if (sucesso) { %><div class="alert alert-success"><%= sucesso %></div><% } %>
<% if (erro) { %><div class="alert alert-error"><%= erro %></div><% } %>

<div class="card-header" style="margin-bottom: 1.5rem;">
  <h3>Gerenciar Alunos — <%= projeto.nome %></h3>
  <a href="/projetos" class="btn btn-sm btn-outline">Voltar para Projetos</a>
</div>

<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card-header" style="display:flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;">
    <h4 style="margin: 0;">Frequência do Projeto</h4>
    <form method="get" action="/projetos/<%= projeto.id %>/alunos" style="display:flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
      <input type="month" name="periodo" class="form-control" value="<%= periodo %>" style="max-width: 180px;">
      <button type="submit" class="btn btn-sm btn-primary">Atualizar</button>
    </form>
  </div>
  <div class="card-body">
    <% if (!relatorioProjeto || relatorioProjeto.length === 0) { %>
      <p class="text-muted">Nenhum lançamento encontrado para o período selecionado.</p>
    <% } else { %>
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Código</th>
              <th>Aluno</th>
              <th>Turma</th>
              <th style="width: 90px; text-align: right;">Aulas</th>
              <th style="width: 70px; text-align: right;">P</th>
              <th style="width: 70px; text-align: right;">F</th>
              <th style="width: 70px; text-align: right;">J</th>
              <th style="width: 110px; text-align: right;">% Pres.</th>
              <th style="width: 110px; text-align: right;">% Falt.</th>
            </tr>
          </thead>
          <tbody>
            <% relatorioProjeto.forEach(function(r) { %>
              <tr>
                <td><%= r.codigo_formatado %></td>
                <td><%= r.nome %></td>
                <td><%= r.turma || '-' %></td>
                <td style="text-align: right;"><%= r.dias_lancados %></td>
                <td style="text-align: right;"><%= r.presencas %></td>
                <td style="text-align: right;"><%= r.faltas %></td>
                <td style="text-align: right;"><%= r.justificadas %></td>
                <td style="text-align: right;"><%= Number(r.percentual_presenca || 0).toFixed(2) %>%</td>
                <td style="text-align: right;"><%= Number(r.percentual_faltas || 0).toFixed(2) %>%</td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<div class="project-students-grid">
  
  <!-- Coluna 1: Alunos Participantes -->
  <div class="card project-students-card" id="alunos-no-projeto">
    <div class="card-header">
      <h4>Alunos no Projeto (<%= totalProjeto %>)</h4>
    </div>
    <div class="card-body project-students-card-body">
      <% if (letrasProjeto.length > 0) { %>
        <% const qsProjetoPrefix = queryProjetoBase && queryProjetoBase.length ? (queryProjetoBase + '&') : ''; %>
        <div class="project-letter-nav">
          <% letrasProjeto.forEach(function(letra) { %>
            <% if (letra === letraProjetoSelecionada) { %>
              <span class="project-letter-chip active"><%= letra %></span>
            <% } else { %>
              <a class="project-letter-chip js-preserve-project-link" href="/projetos/<%= projeto.id %>/alunos?<%= qsProjetoPrefix %>letra_projeto=<%= letra %>#alunos-no-projeto"><%= letra %></a>
            <% } %>
          <% }) %>
        </div>
      <% } %>

      <% if (alunosProjeto.length === 0) { %>
        <p class="text-muted">Nenhum aluno inserido neste projeto ainda.</p>
      <% } else { %>
        <div class="project-letter-summary">Letra <strong><%= letraProjetoSelecionada %></strong>: <%= alunosProjeto.length %> aluno(s)</div>
        <div class="aluno-check-list project-student-list" id="project-student-list">
          <% gruposProjeto.forEach(function(grupo) { %>
            <div class="project-letter-divider"><%= grupo.letra %></div>
            <% grupo.alunos.forEach(function(a) { %>
              <div class="aluno-check-item project-student-item">
                <div>
                  <span class="codigo-cell" style="font-weight: bold;"><%= a.codigo_formatado %></span>
                  <span class="nome-cell"><%= a.nome %></span>
                </div>
                <form action="/projetos/<%= projeto.id %>/alunos/remover" method="post" onsubmit="return confirm('Excluir aluno do projeto?')" class="js-preserve-project-position">
                  <input type="hidden" name="aluno_id" value="<%= a.id %>">
                  <input type="hidden" name="periodo" value="<%= periodo %>">
                  <input type="hidden" name="letra_projeto" value="<%= letraProjetoSelecionada %>">
                  <input type="hidden" name="letra_disponiveis" value="<%= letraDisponiveisSelecionada %>">
                  <button type="submit" class="btn btn-sm btn-danger">Excluir</button>
                </form>
              </div>
            <% }) %>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Coluna 2: Adicionar Alunos -->
  <div class="card project-students-card" id="inserir-alunos">
    <div class="card-header">
      <h4>Inserir Alunos (<%= totalDisponiveis %>)</h4>
    </div>
    <div class="card-body project-students-card-body">
      <% if (letrasDisponiveis.length > 0) { %>
        <% const qsDisponiveisPrefix = queryDisponiveisBase && queryDisponiveisBase.length ? (queryDisponiveisBase + '&') : ''; %>
        <div class="project-letter-nav">
          <% letrasDisponiveis.forEach(function(letra) { %>
            <% if (letra === letraDisponiveisSelecionada) { %>
              <span class="project-letter-chip active"><%= letra %></span>
            <% } else { %>
              <a class="project-letter-chip js-preserve-project-link" href="/projetos/<%= projeto.id %>/alunos?<%= qsDisponiveisPrefix %>letra_disponiveis=<%= letra %>#inserir-alunos"><%= letra %></a>
            <% } %>
          <% }) %>
        </div>
      <% } %>

      <div class="form-group" style="margin-bottom: 1rem;">
        <input type="text" id="filtro-disponiveis" placeholder="Buscar aluno por nome ou código..." class="form-control" oninput="filtrarAlunosDisponiveis(this.value)">
      </div>

      <% if (alunosDisponiveis.length > 0) { %>
        <div class="project-letter-summary">Letra <strong><%= letraDisponiveisSelecionada %></strong>: <%= alunosDisponiveis.length %> aluno(s)</div>
      <% } %>

      <div class="aluno-check-list" id="aluno-check-list">
        <% if (alunosDisponiveis.length === 0) { %>
          <p class="text-muted">Todos os alunos ativos já estão no projeto ou não há alunos cadastrados.</p>
        <% } else { %>
          <% gruposDisponiveis.forEach(function(grupo) { %>
            <div class="project-letter-divider"><%= grupo.letra %></div>
            <% grupo.alunos.forEach(function(a) { %>
              <div class="aluno-check-item available-student" data-busca="<%= a.codigo_nome.toLowerCase() %>">
                <div>
                  <span class="codigo-cell" style="font-weight: bold;"><%= a.codigo_formatado %></span>
                  <span class="nome-cell"><%= a.nome %></span>
                  <div style="font-size: 0.75rem; color: var(--muted);"><%= a.turma_nome %></div>
                </div>
                <form action="/projetos/<%= projeto.id %>/alunos/adicionar" method="post" class="js-preserve-project-position">
                  <input type="hidden" name="aluno_id" value="<%= a.id %>">
                  <input type="hidden" name="periodo" value="<%= periodo %>">
                  <input type="hidden" name="letra_disponiveis" value="<%= letraDisponiveisSelecionada %>">
                  <input type="hidden" name="letra_projeto" value="<%= letraProjetoSelecionada %>">
                  <button type="submit" class="btn btn-sm btn-primary">Inserir</button>
                </form>
              </div>
            <% }) %>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>

</div>

<script>
const projectPageStorageKey = 'projeto-alunos-ui-<%= projeto.id %>';

function salvarPosicaoTelaProjeto() {
  const list = document.getElementById('aluno-check-list');
  const projectList = document.getElementById('project-student-list');
  const filtro = document.getElementById('filtro-disponiveis');
  sessionStorage.setItem(projectPageStorageKey, JSON.stringify({
    scrollY: window.scrollY,
    listScrollTop: list ? list.scrollTop : 0,
    projectListScrollTop: projectList ? projectList.scrollTop : 0,
    filtro: filtro ? filtro.value : ''
  }));
}

function filtrarAlunosDisponiveis(termo) {
  const q = termo.toLowerCase();
  document.querySelectorAll('.available-student').forEach((item) => {
    const busca = item.dataset.busca || '';
    item.style.display = busca.includes(q) ? 'flex' : 'none';
  });
}

document.querySelectorAll('.js-preserve-project-position').forEach((form) => {
  form.addEventListener('submit', () => {
    salvarPosicaoTelaProjeto();
  });
});

document.querySelectorAll('.js-preserve-project-link').forEach((link) => {
  link.addEventListener('click', () => {
    salvarPosicaoTelaProjeto();
  });
});

window.addEventListener('load', () => {
  const saved = sessionStorage.getItem(projectPageStorageKey);
  if (!saved) return;
  try {
    const state = JSON.parse(saved);
    const filtro = document.getElementById('filtro-disponiveis');
    const list = document.getElementById('aluno-check-list');
    const projectList = document.getElementById('project-student-list');
    if (filtro && typeof state.filtro === 'string') {
      filtro.value = state.filtro;
      filtrarAlunosDisponiveis(state.filtro);
    }
    if (typeof state.scrollY === 'number') {
      window.scrollTo({ top: state.scrollY, behavior: 'auto' });
    }
    if (list && typeof state.listScrollTop === 'number') {
      list.scrollTop = state.listScrollTop;
    }
    if (projectList && typeof state.projectListScrollTop === 'number') {
      projectList.scrollTop = state.projectListScrollTop;
    }
  } catch (_) {
    // ignora estado inválido
  }
});
</script>

<%- include('../partials/shell-end') %>
