<%- include('../partials/shell-start') %>

<div class="card" style="max-width:640px">
  <div class="card-header">
    <h3><%= projeto ? 'Editar' : 'Novo' %> projeto</h3>
    <a href="/projetos" class="btn btn-sm btn-outline">Voltar</a>
  </div>
  <div class="card-body">
    <% if (erro) { %><div class="alert alert-error"><%= erro %></div><% } %>

    <form method="post" action="<%= projeto ? '/projetos/' + projeto.id : '/projetos' %>">
      <div class="form-grid">
        <div class="form-group" style="grid-column: span 2">
          <label for="nome">Nome do projeto *</label>
          <input type="text" id="nome" name="nome" required placeholder="Ex: Projeto Presença" value="<%= projeto ? projeto.nome : '' %>">
        </div>
        <div class="form-group" style="grid-column: span 2">
          <label for="descricao">Descrição</label>
          <textarea id="descricao" name="descricao" rows="3" placeholder="Breve descrição do objetivo do projeto"><%= projeto ? projeto.descricao : '' %></textarea>
        </div>
        <div class="form-group">
          <label for="data_inicio">Data de Início *</label>
          <input type="date" id="data_inicio" name="data_inicio" required value="<%= projeto ? (projeto.data_inicio instanceof Date ? projeto.data_inicio.toISOString().slice(0,10) : projeto.data_inicio) : new Date(Date.now() - new Date().getTimezoneOffset() * 60000).toISOString().slice(0,10) %>">
        </div>
        <div class="form-group">
          <label for="data_fim">Data de Fim (opcional)</label>
          <input type="date" id="data_fim" name="data_fim" value="<%= projeto && projeto.data_fim ? (projeto.data_fim instanceof Date ? projeto.data_fim.toISOString().slice(0,10) : projeto.data_fim) : '' %>">
        </div>
      </div>

      <div style="margin-top:1.25rem;display:flex;gap:0.75rem">
        <button type="submit" class="btn btn-primary">Salvar projeto</button>
        <a href="/projetos" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/shell-end') %>
