<%- include('../partials/shell-start') %>

<% if (typeof sucesso !== 'undefined' && sucesso) { %><div class="alert alert-success"><%= sucesso %></div><% } %>
<% if (typeof erro !== 'undefined' && erro) { %><div class="alert alert-error"><%= erro %></div><% } %>

<div class="card">
  <div class="card-header">
    <h3>Relatórios de Lançamentos Diários</h3>
  </div>
  <div class="card-body">
    <% 
      const totalPendencias = (pendenciasNaoLancadas || []).filter((p) => p.status === 'pendente').length;
      const totalSemResponsavel = (pendenciasNaoLancadas || []).filter((p) => p.status === 'sem_responsavel').length;
      const totalLancados = (lancamentos || []).length;
      const turnoSections = [
        lancamentosPorTurno?.matutino,
        lancamentosPorTurno?.vespertino,
        lancamentosPorTurno?.outros,
      ].filter(Boolean);
      const pendenciaSections = [
        pendenciasNaoLancadasPorTurno?.matutino,
        pendenciasNaoLancadasPorTurno?.vespertino,
        pendenciasNaoLancadasPorTurno?.outros,
      ].filter(Boolean);
    %>
    <div class="report-toolbar">
      <form method="get" action="/relatorios" class="report-filter-form">
        <div class="report-filter-fields">
          <div class="form-group">
            <label for="data">Data de referência</label>
            <input type="date" name="data" id="data" value="<%= data %>" class="form-control">
          </div>
          <div class="form-group">
            <label for="horario">Pendências</label>
            <select name="horario" id="horario" class="form-control">
              <option value="" <%= !horarioFiltro ? 'selected' : '' %>>1º e 6º horários</option>
              <option value="1" <%= Number(horarioFiltro) === 1 ? 'selected' : '' %>>Somente 1º horário</option>
              <option value="6" <%= Number(horarioFiltro) === 6 ? 'selected' : '' %>>Somente 6º horário</option>
            </select>
          </div>
        </div>
        <div class="form-group report-filter-submit">
          <button type="submit" class="btn btn-primary">Filtrar</button>
        </div>
      </form>

      <div class="report-toolbar-actions">
        <a href="/relatorios/exportar/excel?data=<%= data %><%= horarioFiltro ? '&horario=' + horarioFiltro : '' %>" class="btn btn-secondary no-print">Exportar Excel</a>
        <button onclick="window.print()" class="btn btn-outline no-print">Imprimir PDF</button>
        <% if (usuario && usuario.perfil === 'admin') { %>
          <form action="/frequencias/limpar" method="post" class="no-print" style="margin:0"
            onsubmit="return confirm('Tem certeza que deseja LIMPAR TODO o histórico de frequência?\\n\\nIsso vai apagar todos os registros já lançados (P/F/J) de todas as turmas, datas e horários.');">
            <button type="submit" class="btn btn-danger">Limpar histórico</button>
          </form>
        <% } %>
      </div>
    </div>

    <div class="stats-grid" style="margin-top:1rem">
      <div class="stat-card">
        <div class="label">Lançamentos realizados</div>
        <div class="value" style="color:var(--success)"><%= totalLancados %></div>
      </div>
      <div class="stat-card">
        <div class="label">Ainda não lançaram</div>
        <div class="value" style="color:var(--danger)"><%= totalPendencias %></div>
      </div>
      <div class="stat-card">
        <div class="label">Sem professor definido</div>
        <div class="value"><%= totalSemResponsavel %></div>
      </div>
    </div>

    <div class="report-section report-section-pendencias" style="margin-top:1.5rem">
      <div class="report-section-header">
        <h3>Ainda não lançaram</h3>
        <span class="badge badge-danger"><%= (pendenciasNaoLancadas || []).length %> turma(s)/horário(s)</span>
      </div>
      <% if (!pendenciasNaoLancadas || pendenciasNaoLancadas.length === 0) { %>
        <div class="alert alert-success" style="margin:0">
          Todos os lançamentos previstos para <%= formatarData(data) %> foram realizados.
        </div>
      <% } else { %>
        <% pendenciaSections.forEach(function(section) { %>
          <% if (section.items.length === 0) return; %>
          <div class="report-turno-block">
            <h4 class="report-turno-title"><%= section.label %></h4>
            <div class="table-wrap report-table-wrap">
              <table class="table table-mobile-cards">
                <thead>
                  <tr>
                    <th>Turma</th>
                    <th>Horário</th>
                    <th>Professor responsável</th>
                    <th>Situação</th>
                  </tr>
                </thead>
                <tbody>
                  <% section.items.forEach(function(item) { %>
                    <tr class="report-row-pendente <%= item.status === 'sem_responsavel' ? 'report-row-sem-responsavel' : '' %>">
                      <td data-label="Turma"><strong><%= item.turma_nome %></strong></td>
                      <td data-label="Horário"><span class="badge badge-info"><%= item.horario %>º Horário</span></td>
                      <td data-label="Professor responsável"><%= item.professor_nome || 'Sem professor definido' %></td>
                      <td data-label="Situação">
                        <% if (item.status === 'pendente') { %>
                          <span class="badge badge-danger">Não lançou</span>
                        <% } else { %>
                          <span class="badge badge-warning">Sem responsável</span>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

    <div class="report-section report-section-lancados" style="margin-top:1.5rem">
      <div class="report-section-header">
        <h3>Lançamentos realizados</h3>
        <span class="badge badge-success"><%= totalLancados %></span>
      </div>
      <% if (!lancamentos || lancamentos.length === 0) { %>
        <div class="alert alert-warning" style="margin:0">
          Nenhum lançamento de frequência encontrado para <%= formatarData(data) %>.
        </div>
      <% } else { %>
        <% turnoSections.forEach(function(section) { %>
          <% if (section.items.length === 0) return; %>
          <div class="report-turno-block">
            <h4 class="report-turno-title"><%= section.label %></h4>
            <div class="table-wrap report-table-wrap">
              <table class="table table-mobile-cards">
                <thead>
                  <tr>
                    <th>Turma</th>
                    <th>Horário</th>
                    <th>Lançado por</th>
                    <th>Data/Hora do registro</th>
                    <th>Total de alunos</th>
                  </tr>
                </thead>
                <tbody>
                  <% section.items.forEach(function(l) { %>
                    <tr class="report-row-lancado">
                      <td data-label="Turma"><strong><%= l.turma_nome %></strong></td>
                      <td data-label="Horário"><span class="badge badge-info"><%= l.horario %>º Horário</span></td>
                      <td data-label="Lançado por"><%= l.lancado_por %></td>
                      <td data-label="Data/Hora do registro"><%= formatarDataHora(l.data_lancamento) %></td>
                      <td data-label="Total de alunos"><%= l.total_registros %> alunos</td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/shell-end') %>
