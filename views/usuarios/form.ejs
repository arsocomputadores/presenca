<%- include('../partials/shell-start') %>

<% const isEdit = !!(usuario_edit && usuario_edit.id); %>
<div class="card" style="max-width:800px">
  <div class="card-header">
    <h3><%= isEdit ? 'Editar' : 'Novo' %> usuário</h3>
    <a href="/usuarios" class="btn btn-sm btn-outline">Voltar</a>
  </div>
  <div class="card-body">
    <% if (erro) { %><div class="alert alert-error"><%= erro %></div><% } %>

    <form method="post" action="<%= isEdit ? '/usuarios/' + usuario_edit.id : '/usuarios' %>">
      <div class="form-grid">
        <div class="form-group">
          <label for="nome">Nome completo *</label>
          <input type="text" id="nome" name="nome" required value="<%= usuario_edit ? usuario_edit.nome : '' %>">
        </div>
        <div class="form-group">
          <label for="cpf">CPF *</label>
          <input type="text" id="cpf" name="cpf" required value="<%= usuario_edit ? usuario_edit.cpf : '' %>" placeholder="000.000.000-00">
        </div>
        <div class="form-group">
          <label for="perfil">Perfil *</label>
          <select id="perfil" name="perfil" required>
            <option value="professor" <%= usuario_edit && usuario_edit.perfil === 'professor' ? 'selected' : '' %>>Professor</option>
            <option value="coordenacao" <%= usuario_edit && usuario_edit.perfil === 'coordenacao' ? 'selected' : '' %>>Coordenação</option>
            <option value="direcao" <%= usuario_edit && usuario_edit.perfil === 'direcao' ? 'selected' : '' %>>Direção</option>
            <option value="admin" <%= usuario_edit && usuario_edit.perfil === 'admin' ? 'selected' : '' %>>Administrador</option>
          </select>
        </div>
        <div class="form-group">
          <label for="ativo">Status</label>
          <select id="ativo" name="ativo">
            <option value="1" <%= usuario_edit && Number(usuario_edit.ativo) === 1 ? 'selected' : '' %>>Ativo</option>
            <option value="0" <%= usuario_edit && Number(usuario_edit.ativo) === 0 ? 'selected' : '' %>>Inativo</option>
          </select>
        </div>
        <div class="form-group">
          <label for="senha">Senha <%= isEdit ? '(deixe em branco para manter)' : '*' %></label>
          <input type="password" id="senha" name="senha" <%= isEdit ? '' : 'required' %>>
        </div>
      </div>

      <% if (usuario_edit && usuario_edit.perfil === 'professor' || !usuario_edit) { %>
      <div style="margin-top:1.5rem; padding: 1rem; background: #f8f9fa; border-radius: 6px;">
        <div class="form-group" style="margin-bottom:0">
          <label for="pode_consultar_outras_turmas" style="display:flex; gap:0.5rem; align-items:flex-start; cursor:pointer;">
            <input type="checkbox" id="pode_consultar_outras_turmas" name="pode_consultar_outras_turmas" value="1" <%= usuario_edit && Number(usuario_edit.pode_consultar_outras_turmas) === 1 ? 'checked' : '' %>>
            <span>
              <strong>Permitir consulta de frequência em outras turmas</strong>
              <div class="text-muted" style="margin-top:0.25rem; font-size:0.9rem;">Se marcado, o professor poderá consultar a frequência de turmas fora da sua atribuição de 1º/6º horário, sem perder o bloqueio de lançamento nas turmas não designadas.</div>
            </span>
          </label>
        </div>
      </div>
      <% } %>

      <div style="margin-top:1.5rem">
        <h4>Vincular turmas</h4>
        <p class="text-muted" style="margin-top:0.25rem; margin-bottom:0.75rem;">
          <% if (usuario_edit && usuario_edit.perfil === 'professor') { %>
            Selecione todas as turmas do professor. Para lançamento de frequência, o acesso será liberado apenas nas turmas em que ele estiver designado no 1º ou 6º horário.
          <% } else { %>
            Selecione as turmas que este usuário deverá acompanhar.
          <% } %>
        </p>
        <div class="turmas-grid" style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); margin-top: 0.5rem;">
          <% turmas.forEach(function(t) { %>
            <label style="display: flex; gap: 0.5rem; align-items: center; background: #f8f9fa; padding: 0.5rem; border-radius: 4px; cursor: pointer;">
              <input type="checkbox" name="turmas_ids" value="<%= t.id %>"
                <%= usuario_edit && usuario_edit.turmas_ids && (Array.isArray(usuario_edit.turmas_ids) ? usuario_edit.turmas_ids.map(Number).includes(Number(t.id)) : String(usuario_edit.turmas_ids).split(',').map(Number).includes(Number(t.id))) ? 'checked' : '' %>>
              <span><%= t.nome %> (<%= t.serie %>)</span>
            </label>
          <% }) %>
        </div>
      </div>

      <div style="margin-top:1.25rem;display:flex;gap:0.75rem">
        <button type="submit" class="btn btn-primary">Salvar usuário</button>
        <a href="/usuarios" class="btn btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/shell-end') %>
